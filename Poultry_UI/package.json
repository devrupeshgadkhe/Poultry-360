{
  "name": "poultry-erp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "init": "npm install && npm install --prefix Poultry_UI",
    "clean": "taskkill /F /IM PoultryERP.API.exe /T || exit 0",
    "dev": "concurrently \"dotnet run --project PoultryERP.API/PoultryERP.API.csproj --urls=https://localhost:56700;http://localhost:56701\" \"npm run dev --prefix Poultry_UI\"",
    "build": "npm run build --prefix Poultry_UI",
    "lint": "npm run lint --prefix Poultry_UI"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.475.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.0"
  }
}